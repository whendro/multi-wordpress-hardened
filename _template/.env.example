# ── Site identity ────────────────────────────────────────────────────────────
# Used for container names and volume names — no spaces, no special chars
# Examples: wp-site1, wp-shop, wp-blog
SITE_NAME=wp-site1

# ── Database ─────────────────────────────────────────────────────────────────
# Use your MariaDB container name as hostname
DB_HOST=your_mariadb_container:3306
DB_NAME=wp_site1
DB_USER=wp_site1_user
DB_PASSWORD=CHANGE_ME

# Never use default wp_ prefix
TABLE_PREFIX=wp_s1_

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=your_redis_container
REDIS_PASSWORD=CHANGE_ME
# Unique per site — prevents cross-site cache collision
REDIS_PREFIX=s1_
# Use a different DB index (0–15) per site
REDIS_DB=0
